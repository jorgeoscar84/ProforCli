{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account containing role and distributor profile",
      "type": "object",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["admin", "distributor"],
          "description": "The role of the user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "profile": {
          "type": "object",
          "description": "Distributor profile details",
          "properties": {
            "companyName": { "type": "string" },
            "ruc": { "type": "string" },
            "ownerName": { "type": "string" },
            "phone": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "logoUrl": { "type": "string" },
            "primaryColor": { "type": "string" }
          }
        }
      },
      "required": ["role", "email"]
    },
    "Product": {
      "title": "Product",
      "description": "Global product available for all distributors",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" }
      },
      "required": ["name", "basePrice"]
    },
    "AdminSettings": {
      "title": "Admin Settings",
      "description": "Global settings configured by the admin",
      "type": "object",
      "properties": {
        "aiContext": { "type": "string" },
        "ivaPercentage": { "type": "number" },
        "defaultLogoUrl": { "type": "string" },
        "primaryColor": { "type": "string" }
      },
      "required": ["aiContext", "ivaPercentage"]
    },
    "Proforma": {
      "title": "Proforma",
      "description": "A quote generated by a distributor",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string", "description": "The UID of the distributor who created this proforma" },
        "date": { "type": "string", "format": "date-time" },
        "distributor": {
          "type": "object",
          "properties": {
             "companyName": { "type": "string" },
             "ruc": { "type": "string" },
             "ownerName": { "type": "string" },
             "phone": { "type": "string" },
             "email": { "type": "string", "format": "email" },
             "logoUrl": { "type": "string" },
             "primaryColor": { "type": "string" }
          }
        },
        "client": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "ruc": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "duration": { "type": "number" },
              "durationUnit": { "type": "string" },
              "unitPrice": { "type": "number" }
            }
          }
        },
        "subtotal": { "type": "number" },
        "iva": { "type": "number" },
        "total": { "type": "number" },
        "aiCopy": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["ownerId", "date", "distributor", "client", "items", "subtotal", "iva", "total"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles."
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Stores global products."
    },
    "settings/admin": {
      "schema": { "$ref": "#/entities/AdminSettings" },
      "description": "Stores global admin settings."
    },
    "proformas/{proformaId}": {
      "schema": { "$ref": "#/entities/Proforma" },
      "description": "Stores proformas created by distributors."
    }
  }
}
